  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net https://accounts.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; connect-src 'self' https://api.anthropic.com https://*.supabase.co https://www.googleapis.com https://accounts.google.com; img-src 'self' data:; frame-src https://accounts.google.com

/config.json
  X-Robots-Tag: noindex
  Cache-Control: no-store
